    struct TwoDPoint G3;
    struct TwoDPoint G4;
    struct TwoDPoint B1;
    struct TwoDPoint B2;
    struct TwoDPoint B3;
    struct TwoDPoint B4;
    struct TwoDPoint R1;
    struct TwoDPoint R2;
    struct TwoDPoint R3;
    struct TwoDPoint R4;

};

void draw_dodecahedron(struct Dodecahedron d) {

    // Helper macro: draw one closed pentagon (5 edges)
    #define PENT(a,b,c,dd,e) \
        line(a.x,a.y, b.x,b.y, WHITE); \
        line(b.x,b.y, c.x,c.y, WHITE); \
        line(c.x,c.y, dd.x,dd.y, WHITE); \
        line(dd.x,dd.y, e.x,e.y, WHITE); \
        line(e.x,e.y, a.x,a.y, WHITE);

    // All 12 pentagonal faces
    PENT(d.O1, d.G1, d.G3, d.O6, d.R1)
    PENT(d.O3, d.G1, d.G3, d.O5, d.R2)
    PENT(d.O5, d.G3, d.O6, d.B3, d.B4)
    PENT(d.O1, d.G1, d.O3, d.B2, d.B1)
    PENT(d.O3, d.R2, d.R4, d.O4, d.B2)
    PENT(d.O1, d.R1, d.R3, d.O8, d.B1)
    PENT(d.O6, d.R1, d.R3, d.O7, d.B3)
    PENT(d.O5, d.B4, d.O2, d.R4, d.R2)
    PENT(d.B2, d.B1, d.O8, d.G2, d.O4)
    PENT(d.B3, d.B4, d.O2, d.G4, d.O7)
    PENT(d.R3, d.O7, d.G4, d.G2, d.O8)
    PENT(d.R4, d.O2, d.G4, d.G2, d.O4)

    #undef PENT
}

struct Dodecahedron updateDodecahedron() {

    struct Dodecahedron d;
    int w = DODECA_W;
    double p = PSI;

    d.O1 = rotatePoint(w, w, w);
    d.O2 = rotatePoint(-w, -w, -w);
    d.O3 = rotatePoint(-w ,w,w );
    d.O4 = rotatePoint(-w, -w, w);
    d.O5 = rotatePoint(-w, w, -w);
    d.O6 = rotatePoint(w, w, -w);
    d.O7 = rotatePoint(w, -w, -w);
    d.O8 = rotatePoint(w, -w, w);

    d.G1 = rotatePoint(0, p*w , w/p);
    d.G2 = rotatePoint(0, -p*w, w/p);
    d.G3 = rotatePoint(0, p*w, -w/p);
    d.G4 = rotatePoint(0, -p*w, -w/p);

    d.B1 = rotatePoint(w/p, 0, w*p);
    d.B2 = rotatePoint(-w/p, 0, w*p);
    d.B3 = rotatePoint(w/p, 0, -w*p);
    d.B4 = rotatePoint(-w/p, 0, -w*p);

    d.R1 = rotatePoint(w*p, w/p,0 );
    d.R2 = rotatePoint(-w*p, w/p,0 );
    d.R3 = rotatePoint(w*p,-w/p ,0 );
    d.R4 = rotatePoint(-w*p,-w/p ,0 );

    draw_dodecahedron(d);
	
	

    return d;

}



// ────────────────────────────────────────────────────────────────────────────
// hardware I/O
// ────────────────────────────────────────────────────────────────────────────
void wait_for_vsync(void) {
    volatile int *ctrl = (int *)0xFF203020;
    *ctrl = 1;
    while ((*(ctrl+3) & 0x01) != 0);
}



// ────────────────────────────────────────────────────────────────────────────
// main game loop
// ────────────────────────────────────────────────────────────────────────────

int main(void) {
	
	volatile int *ctrl = (int *)0xFF203020;

    // point both buffers at Buffer1 (single buffering for now)
    *(ctrl + 1) = (int)Buffer1;   // back buffer address
    *ctrl = 1;                     // swap once to make it front
    while ((*(ctrl + 3) & 0x01) != 0);  // wait for swap
    *(ctrl + 1) = (int)Buffer1;   // point back buffer here too
	
    while (1) {
        clear(BLACK);
        struct Dodecahedron d = updateDodecahedron();
        wait_for_vsync();
        theta = (theta + 1) % 360;
    }
    return 0;
}
int theta = 5;


struct TwoDPoint rotatePoint(int x, int y, int z) {

    struct TwoDPoint p;
    int d = DODECAHEDRON_DIST;
    int t = theta;
	y=-y;
    p.x = (-((x*cos_table[t])-(z*sin_table[t]))*d)  /  ((x*(sin_table[t]))+(z*(cos_table[t])-d))  +160;
    p.y = (-(y)*d)  /  ((x*(sin_table[t]))+(z*(cos_table[t])-d))  +120;

    //plot_pixel(p.x, p.y, WHITE);

    return p;
}

struct Dodecahedron {

    struct TwoDPoint O1;
    struct TwoDPoint O2;
    struct TwoDPoint O3;
    struct TwoDPoint O4;
    struct TwoDPoint O5;
    struct TwoDPoint O6;
    struct TwoDPoint O7;
    struct TwoDPoint O8;
    struct TwoDPoint G1;
    struct TwoDPoint G2;
    struct TwoDPoint G3;
    struct TwoDPoint G4;
    struct TwoDPoint B1;
    struct TwoDPoint B2;
    struct TwoDPoint B3;
    struct TwoDPoint B4;
    struct TwoDPoint R1;
    struct TwoDPoint R2;
    struct TwoDPoint R3;
    struct TwoDPoint R4;

};

void draw_dodecahedron(struct Dodecahedron d) {

	int t = theta;
    // Helper macro: draw one closed pentagon (5 edges)
    #define PENT(a,b,c,dd,e) \
        line(a.x,a.y, b.x,b.y, WHITE); \
        line(b.x,b.y, c.x,c.y, WHITE); \
        line(c.x,c.y, dd.x,dd.y, WHITE); \
        line(dd.x,dd.y, e.x,e.y, WHITE); \
        line(e.x,e.y, a.x,a.y, WHITE);

    // All 12 pentagonal faces
    if((t>=15) && (t<=165)){PENT(d.O1, d.G1, d.G3, d.O6, d.R1)}
    if((t>=195) && (t<=345)){PENT(d.O3, d.G1, d.G3, d.O5, d.R2)}
    if((t>=99) && (t<=261)){PENT(d.O5, d.G3, d.O6, d.B3, d.B4)}
    if((t>=279) || (t<=81)){PENT(d.O1, d.G1, d.O3, d.B2, d.B1)}
    if((t>220) || (t<24)){PENT(d.O3, d.R2, d.R4, d.O4, d.B2)}
    if((t>336) || (t<139)){PENT(d.O1, d.R1, d.R3, d.O8, d.B1)}
    if((t>40) && (t<203)){PENT(d.O6, d.R1, d.R3, d.O7, d.B3)}
    if((t>156) && (t<320)){PENT(d.O5, d.B4, d.O2, d.R4, d.R2)}
    if((t>=279) || (t<=81)){PENT(d.B2, d.B1, d.O8, d.G2, d.O4)}
    if((t>=99) && (t<=261)){PENT(d.B3, d.B4, d.O2, d.G4, d.O7)}
    if((t>=15) && (t<=165)){PENT(d.R3, d.O7, d.G4, d.G2, d.O8)}
    if((t>=195) && (t<=345)){PENT(d.R4, d.O2, d.G4, d.G2, d.O4)}

    #undef PENT
}

struct Dodecahedron updateDodecahedron() {

    struct Dodecahedron d;
    int w = DODECA_W;
    double p = PSI;

    d.O1 = rotatePoint(w, w, w);
    d.O2 = rotatePoint(-w, -w, -w);
    d.O3 = rotatePoint(-w ,w,w );
    d.O4 = rotatePoint(-w, -w, w);
    d.O5 = rotatePoint(-w, w, -w);
    d.O6 = rotatePoint(w, w, -w);
    d.O7 = rotatePoint(w, -w, -w);
    d.O8 = rotatePoint(w, -w, w);

    d.G1 = rotatePoint(0, p*w , w/p);
    d.G2 = rotatePoint(0, -p*w, w/p);
    d.G3 = rotatePoint(0, p*w, -w/p);
    d.G4 = rotatePoint(0, -p*w, -w/p);

    d.B1 = rotatePoint(w/p, 0, w*p);
    d.B2 = rotatePoint(-w/p, 0, w*p);
    d.B3 = rotatePoint(w/p, 0, -w*p);
    d.B4 = rotatePoint(-w/p, 0, -w*p);

    d.R1 = rotatePoint(w*p, w/p,0 );
    d.R2 = rotatePoint(-w*p, w/p,0 );
    d.R3 = rotatePoint(w*p,-w/p ,0 );
    d.R4 = rotatePoint(-w*p,-w/p ,0 );

    draw_dodecahedron(d);
	
	

    return d;

}



